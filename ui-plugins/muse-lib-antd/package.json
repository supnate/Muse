{
  "name": "@ebay/muse-lib-antd",
  "version": "1.3.5",
  "repository": "",
  "type": "module",
  "muse": {
    "type": "lib",
    "devConfig": {
      "app": "musemanager",
      "env": "staging"
    }
  },
  "files": [
    "build",
    "src",
    "MUSE_README.md"
  ],
  "scripts": {
    "start": "cross-env NODE_PATH=./node_modules vite",
    "build": "cross-env NODE_PATH=./node_modules vite build",
    "build:dev": "cross-env NODE_ENV=development vite build --mode development",
    "build:test": "muse-cra-patch && cross-env NODE_PATH=./node_modules MUSE_TEST_BUILD=true FAST_REFRESH=false craco build",
    "test": "muse-cra-patch && craco test --ci --watchAll=false --passWithNoTests --coverage",
    "test:dev": "muse-cra-patch && craco test --coverage",
    "test:config": "muse-cra-patch && craco test --showConfig",
    "deploy": "pnpm build && pnpm build:dev && muse release && muse deploy nateapp staging",
    "postbuild": "cp MUSE_README.md ./build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.23.2",
    "@ebay/muse-core": "^1.0.40",
    "@ebay/muse-vite-plugin": "^1.0.56",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.3.0",
    "less": "^4.6.4",
    "vite": "^8.0.7"
  },
  "dependencies": {
    "@ant-design/icons": "5.3.7",
    "@ebay/muse-lib-react": "1.3.0",
    "@ebay/nice-form-react": "2.0.3",
    "antd": "5.19.0",
    "history": "5.3.0",
    "js-plugin": "1.1.0",
    "lodash": "4.17.21",
    "moment": "2.29.4",
    "prop-types": "15.8.1",
    "react-copy-to-clipboard": "5.1.0",
    "react-highlight-words": "0.20.0",
    "react-syntax-highlighter": "15.5.0"
  },
  "pnpm": {}
}
